@cli.command()
@click.option("--multi", "-m", default=1, type=int, help="Multi-pull (e.g. -m 10 for 十連抽)")
def gacha(multi):
    """Random gacha pull with animation.

    Examples:
      buddy gacha          Single pull
      buddy gacha -m 10    十連抽
    """
    import secrets
    import time

    user_id = get_user_id()
    pulls = []

    for n in range(multi):
        salt = secrets.token_urlsafe(12)[:SALT_LEN]
        r = roll_companion(user_id, salt, use_bun=False)
        pulls.append(r)

    # Sort: best (highest rarity) last for dramatic reveal
    rarity_order = {r: i for i, r in enumerate(RARITIES)}
    pulls.sort(key=lambda r: (rarity_order[r["rarity"]], r["shiny"]))

    for i, r in enumerate(pulls):
        color = RARITY_COLORS[r["rarity"]]
        stars = RARITY_STARS[r["rarity"]]
        shiny = "✨ SHINY ✨" if r["shiny"] else ""
        rarity_idx = rarity_order[r["rarity"]]

        if multi > 1:
            console.print(f"\n[dim]── Pull {i+1}/{multi} ──[/]")

        # Animation: stars appear one by one
        if rarity_idx >= 3:  # epic or legendary — slow reveal
            for s in range(1, rarity_idx + 2):
                partial_stars = "★" * s
                console.print(f"\r  [{color}]{partial_stars}[/]", end="")
                time.sleep(0.3)
            console.print()
            time.sleep(0.2)
        else:
            console.print(f"  [{color}]{stars}[/]")
            time.sleep(0.1)

        # Reveal species
        console.print(f"  [{color} bold]{stars} {r['rarity'].upper()}[/]  [bold]{r['species'].upper()}[/]  {shiny}")

        # Show sprite for epic+ or shiny
        if rarity_idx >= 3 or r["shiny"]:
            sprite_lines = render_sprite(r["species"], r["eye"], r["hat"])
            console.print()
            for line in sprite_lines:
                console.print(f"    [{color}]{line}[/]")
            console.print()
            best = max(r["stats"].items(), key=lambda x: x[1])
            console.print(f"    Eye: {r['eye']}  Hat: {r['hat']}  Best: {best[0]}:{best[1]}")

        console.print(f"    [dim]salt: {r['salt']}[/]")

        if multi > 1 and i < multi - 1:
            time.sleep(0.15)

    # Summary for multi-pull
    if multi > 1:
        console.print(f"\n[bold]═══ Summary ({multi} pulls) ═══[/]")
        from collections import Counter
        rarity_counts = Counter(r["rarity"] for r in pulls)
        for rar in RARITIES:
            if rarity_counts[rar] > 0:
                c = RARITY_COLORS[rar]
                console.print(f"  [{c}]{RARITY_STARS[rar]} {rar}: {rarity_counts[rar]}[/]")
        shiny_count = sum(1 for r in pulls if r["shiny"])
        if shiny_count:
            console.print(f"  ✨ Shiny: {shiny_count}")
        console.print()

    # Ask to patch if got something good
    best_pull = max(pulls, key=lambda r: (rarity_order[r["rarity"]], r["shiny"]))
    best_rarity = rarity_order[best_pull["rarity"]]
    if best_rarity >= 3 or best_pull["shiny"]:
        color = RARITY_COLORS[best_pull["rarity"]]
        console.print(f"[{color} bold]Best pull: {RARITY_STARS[best_pull['rarity']]} {best_pull['rarity'].upper()} {best_pull['species']}[/]")
        console.print(f"[dim]To use this companion: buddy patch {best_pull['salt']}[/]")


