def get_prompt_file() -> Path:
    return Path.home() / ".claude" / "buddy-prompt.txt"


def patch_companion_prompt(custom_prompt: str, runtime: str = "native"):
    """Patch the companion intro prompt in cli.js (npm) or native binary."""
    if runtime == "npm":
        cli_js = get_npm_cli_js()
        if not cli_js.exists():
            console.print(f"[red]cli.js not found: {cli_js}[/]")
            sys.exit(1)
        content = cli_js.read_text()

        # Find the template — either original or previously patched
        match = re.search(
            r"A small \$\{\w\} named \$\{\w\} [^`]+",
            content,
        )
        if not match:
            # Try finding any companion prompt (might have been custom-patched before)
            # Look for the function that contains "sits beside" or our marker
            match = re.search(r'# Companion\\n\\n[^`]*', content)
            if not match:
                console.print("[red]Could not find companion prompt in cli.js[/]")
                sys.exit(1)

        old_prompt = match.group(0)

        # Extract the variable names for species and name from the original
        var_match = re.search(r'\$\{(\w)\} named \$\{(\w)\}', old_prompt)
        if var_match:
            species_var = var_match.group(1)
            name_var = var_match.group(2)
        else:
            species_var = "K"
            name_var = "q"

        # Build new prompt with the user's custom text, keeping the template vars
        new_prompt = (
            f"A small ${{{species_var}}} named ${{{name_var}}} sits beside the user's input box. "
            f"{custom_prompt} "
            f"When the user addresses ${{{name_var}}} directly, its bubble will answer."
        )

        content = content.replace(old_prompt, new_prompt)
        cli_js.write_text(content)
        console.print(f"[dim]Patched companion prompt in cli.js[/]")
    else:
        # Native binary — find and replace the prompt string
        binary = get_claude_binary()
        data = binary.read_bytes()

        # Find the original or current prompt
        search_str = b"sits beside the user's input box and occasionally comments in a speech bubble"
        idx = data.find(search_str)
        if idx == -1:
            search_str = b"sits beside the user's input box"
            idx = data.find(search_str)
        if idx == -1:
            console.print("[red]Could not find companion prompt in binary[/]")
            console.print("[dim]Try: buddy prompt --runtime npm[/]")
            sys.exit(1)

        # Find the full prompt boundaries (backtick-delimited template string)
        # Walk backwards to find "A small"
        start = data.rfind(b"A small", max(0, idx - 200), idx)
        # Walk forwards to find end of the template section (next backtick or function)
        end = data.find(b"When the user addresses", idx)
        if end != -1:
            end = data.find(b".", end) + 1
        else:
            end = data.find(b"`", idx)

        if start == -1 or end == -1:
            console.print("[red]Could not determine prompt boundaries in binary[/]")
            sys.exit(1)

        old_bytes = data[start:end]
        old_len = len(old_bytes)

        # Build replacement — must be EXACTLY the same byte length
        # Extract variable names from the original
        old_text = old_bytes.decode("utf-8", errors="replace")
        var_match = re.search(r'\$\{(\w+)\}[^$]*\$\{(\w+)\}', old_text)
        species_var = var_match.group(1) if var_match else "K"
        name_var = var_match.group(2) if var_match else "q"

        new_text = (
            f"A small ${{{species_var}}} named ${{{name_var}}} sits beside the user's input box. "
            f"{custom_prompt} "
            f"When the user addresses ${{{name_var}}} directly, its bubble will answer."
        )

        new_bytes = new_text.encode("utf-8")

        if len(new_bytes) > old_len:
            # Truncate if too long
            new_bytes = new_bytes[:old_len]
            console.print(f"[yellow]Warning: prompt truncated to {old_len} bytes to fit binary[/]")
        elif len(new_bytes) < old_len:
            # Pad with spaces
            new_bytes = new_bytes + b" " * (old_len - len(new_bytes))

        data = data[:start] + new_bytes + data[end:]
        binary.write_bytes(data)

        if shutil.which("codesign"):
            subprocess.run(["codesign", "--force", "--sign", "-", str(binary)], capture_output=True)

        console.print(f"[dim]Patched companion prompt in native binary ({old_len} bytes)[/]")

    # Save prompt to file for persistence across updates
    get_prompt_file().parent.mkdir(parents=True, exist_ok=True)
    get_prompt_file().write_text(custom_prompt)
    console.print(f"[dim]Saved to {get_prompt_file()}[/]")


