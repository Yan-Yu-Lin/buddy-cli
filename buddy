@cli.command()
@click.argument("terms", nargs=-1, required=True)
@click.option("--min-stat", "-m", multiple=True, help="Filter by min stat, e.g. DEBUGGING:90")
@click.option("--sort", "-s", "sort_stat", help="Sort results by stat name")
@click.option("--limit", "-l", default=25, help="Max results (default 25)")
def search(terms, min_stat, sort_stat, limit):
    """Search for companions matching traits (FNV-1a, version-proof).

    Examples:
      buddy search legendary dragon wizard
      buddy search "legendary shiny dragon" --min-stat DEBUGGING:90
      buddy search epic cat --sort SNARK
    """
    user_id = get_user_id()
    term_list = []
    for t in terms:
        term_list.extend(t.lower().split())

    min_stats = {}
    for ms in min_stat:
        parts = ms.split(":")
        if len(parts) == 2:
            min_stats[parts[0].upper()] = int(parts[1])

    console.print(f"[bold]Searching:[/] {' '.join(term_list)}")
    console.print(f"[dim]User: {user_id[:8]}...  (FNV-1a, version-proof)[/]")
    if min_stats:
        console.print(f"[dim]Min stats: {min_stats}[/]")
    console.print("---")

    # Always use Python FNV-1a — matches the patched binary (no Bun version dependency)
    import secrets
    results = []
    searched = 0
    while len(results) < limit and searched < 50_000_000:
        salt = secrets.token_urlsafe(12)[:SALT_LEN]
        r = roll_companion(user_id, salt, use_bun=False)
        searched += 1
        pool = [r["rarity"], r["species"], r["eye"], EYE_NAMES.get(r["eye"], ""),
                r["hat"], "shiny" if r["shiny"] else ""]
        if all(any(t in p.lower() for p in pool) for t in term_list):
            if all(r["stats"].get(k, 0) >= v for k, v in min_stats.items()):
                results.append(r)
        if searched % 500_000 == 0 and len(results) < limit:
            console.print(f"[dim]  ...{searched:,} searched, {len(results)} found[/]")
    console.print(f"[dim]Found {len(results)} in {searched:,} rolls[/]")

    if sort_stat and results:
        results.sort(key=lambda r: r["stats"].get(sort_stat.upper(), 0), reverse=True)

    for r in results:
        color = RARITY_COLORS[r["rarity"]]
        stars = RARITY_STARS[r["rarity"]]
        shiny = "✨ " if r["shiny"] else ""
        hat_str = f'[{r["hat"]}]' if r["hat"] != "none" else ""
        best = max(r["stats"].items(), key=lambda x: x[1])
        console.print(
            f"[{color}]{stars}[/] {r['rarity'].upper()} {shiny}{r['species']} "
            f"{r['eye']} {hat_str} | best: {best[0]}:{best[1]} | "
            f"[dim]salt: {r['salt']}[/]"
        )


